# ============================================================
# CONFIGURAÇÕES DO SISTEMA HABITAÇÃO MCMV
# ============================================================
# Copie este arquivo para .env e ajuste os valores conforme necessário

# ============================================================
# DJANGO
# ============================================================
SECRET_KEY=django-insecure-CHANGE-THIS-TO-A-RANDOM-STRING-IN-PRODUCTION
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,habitacao.gov.br

# ============================================================
# DATABASE (MySQL)
# ============================================================
DB_NAME=habitacao_db
DB_USER=habitacao_user
DB_PASSWORD=strong_password_here
DB_HOST=db
DB_PORT=3306
DB_ROOT_PASSWORD=root_strong_password

# ============================================================
# PORTS
# ============================================================
WEB_PORT=8000
DB_PORT=3307
NGINX_PORT=80
NGINX_SSL_PORT=443
REDIS_PORT=6379

# ============================================================
# SUPERUSER (Criado automaticamente no primeiro start)
# ============================================================
ADMIN_EMAIL=admin@habitacao.gov.br
ADMIN_PASSWORD=admin_strong_password

# ============================================================
# CORS
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://habitacao.gov.br

# ============================================================
# EMAIL (Opcional - para notificações)
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@habitacao.gov.br
EMAIL_HOST_PASSWORD=email_password_here
DEFAULT_FROM_EMAIL=Sistema Habitação <noreply@habitacao.gov.br>

# ============================================================
# INITIAL DATA
# ============================================================
LOAD_INITIAL_DATA=true

# ============================================================
# JWT
# ============================================================
JWT_ACCESS_TOKEN_LIFETIME=8
JWT_REFRESH_TOKEN_LIFETIME=168

# ============================================================
# SENTRY (Opcional - para monitoramento de erros)
# ============================================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================
# AWS S3 (Opcional - para armazenamento de arquivos)
# ============================================================
# USE_S3=False
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_STORAGE_BUCKET_NAME=habitacao-documents
# AWS_S3_REGION_NAME=us-east-1
